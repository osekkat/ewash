# ── Meta Cloud API ────────────────────────────────────────────────
# developers.facebook.com → "ewash agent" app → Paramètres → Basique
# Click "Afficher" next to "Clé secrète de l'app"
META_APP_SECRET=***

# A random string YOU pick. Also paste this same value into the
# Meta webhook config screen as "Verify token".
META_VERIFY_TOKEN=***

# Temporary 24h token from "WhatsApp → Configuration de l'API" for first test.
# Replace later with a long-lived System User token (see README).
META_ACCESS_TOKEN=***

# Your Meta test number phone_number_id.
META_PHONE_NUMBER_ID=[REDACTED]
META_WABA_ID=[REDACTED]

# ── Local dev only ────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ── v0.3 admin / persistence ─────────────────────────────────────
# Leave DATABASE_URL empty locally until Postgres is provisioned.
DATABASE_URL=
# Browser-native Basic Auth prompt for /admin.
ADMIN_PASSWORD=***
INTERNAL_CRON_SECRET=***
ADMIN_DEFAULT_LOCALE=fr

# ── PWA API (v0.4 milestone) ─────────────────────────────────────
# Comma-separated exact origins. Production Vercel URL + localhost dev.
ALLOWED_ORIGINS=https://your-pwa.vercel.app,http://localhost:8080
# Single regex matching Vercel preview-branch URLs. Optional; production
# should rely on the exact list. Useful for PR previews that get unique URLs.
ALLOWED_ORIGIN_REGEX=^https://ewash-mobile-app-.*\.vercel\.app$

# Set to "false" to unmount the /api/v1/* router (rollback switch).
EWASH_API_ENABLED=true

# Rate limits — slowapi syntax, see https://limits.readthedocs.io
RATE_LIMIT_BOOKINGS_PER_PHONE=5/hour
RATE_LIMIT_BOOKINGS_PER_IP=20/hour
RATE_LIMIT_CATALOG_PER_IP=60/minute
RATE_LIMIT_PROMO_PER_IP=60/hour
RATE_LIMIT_BOOKINGS_LIST_PER_TOKEN=60/hour

# PUBLIC_BASE_URL is already required for tariff-image links served from
# /static — no change needed for the PWA milestone.
